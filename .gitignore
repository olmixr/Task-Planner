# Keep Maven wrapper files available
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# JavaFX / jlink generated images
app/
jlink-image/
jlinkZip/

# Logs and crash reports
*.log
logs/
hs_err_pid*
replay_pid*

